# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=""

# Database — set automatically when you run: vercel env pull .env.local
# Prisma Postgres sets POSTGRES_URL (used by both the app and prisma db push)
POSTGRES_URL=""
# DATABASE_URL=""  # fallback if not using Vercel/Prisma Postgres

# AWS S3 — file storage for uploaded project files
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Google Gemini — AI report generation (free at aistudio.google.com)
GEMINI_API_KEY=""
