# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=""

# Database — standard PostgreSQL connection string
# For Vercel Postgres, POSTGRES_PRISMA_URL is set automatically when you link a database
DATABASE_URL="postgresql://user:password@host:5432/database"
# POSTGRES_PRISMA_URL=""       # pooled via PgBouncer — preferred on Vercel
# POSTGRES_URL_NON_POOLING=""  # direct — use for: npx prisma db push

# AWS S3 — file storage for uploaded project files
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Anthropic — AI report generation (claude-opus-4-7)
ANTHROPIC_API_KEY=""
